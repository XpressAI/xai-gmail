@xai_component
class GmailCreateReply(Component):
    message_id: InCompArg[str]
    reply_body: InCompArg[str]
    draft: OutArg[any]
    
    def execute(self, ctx) -> None:
        # create gmail api client
        service = ctx['gmail_service']

        try:
            # Get the original message to reply to
            original_message = service.users().messages().get(userId='me', id=self.message_id.value).execute()
            original_sender = None
            
            # Extract the sender's email address
            if 'payload' in original_message and 'headers' in original_message['payload']:
                for header in original_message['payload']['headers']:
                    if header['name'] == 'From':
                        original_sender = header['value']
                        break
            
            # Create the reply message
            message = EmailMessage()
            message.set_content(self.reply_body.value)
            message['To'] = original_sender
            message['Subject'] = f"Re: {original_message['snippet']}"  # Use snippet for the original subject
            
            # Encode message
            encoded_message = base64.urlsafe_b64encode(message.as_bytes()).decode()
            create_message = {
                'message': {
                    'raw': encoded_message
                }
            }

            # Create draft
            draft = service.users().drafts().create(userId="me", body=create_message).execute()
            self.draft.value = draft
        except HttpError as error:
            print(f'An error occurred: {error}')
            self.draft.value = None
