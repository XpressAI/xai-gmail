@xai_component
class GmailCreateDraft(Component):
    message_from: InCompArg[str]
    message_to: InCompArg[str]
    subject: InCompArg[str]
    body: InCompArg[str]
    
    draft: OutArg[any]
    
    
    def execute(self, ctx) -> None:
        # create gmail api client
        service = ctx['gmail_service']

        message = EmailMessage()

        message.set_content(self.body.value)

        message['To'] = self.message_to.value
        message['From'] = self.message_from.value
        message['Subject'] = self.subject.value

        # encoded message
        encoded_message = base64.urlsafe_b64encode(message.as_bytes()).decode()

        create_message = {
            'message': {
                'raw': encoded_message
            }
        }

        draft = service.users().drafts().create(userId="me", body=create_message).execute()
        self.draft.value = draft


