# If modifying these SCOPES, delete the file token.pickle.
READONLY_SCOPE = ['https://www.googleapis.com/auth/gmail.readonly']
READWRITE_SCOPE = ['https://www.googleapis.com/auth/gmail.modify']

@xai_component
class GmailAuthenticate(Component):
    is_readwrite: InCompArg[bool]
    token_path: InArg[str]
    client_secret_path: InArg[str]
    labels: OutArg[list]
    
    def execute(self, ctx) -> None:
        creds = None
        token_path = if self.token_path.value is not None then self.token_path.value else 'token.pickle'

        if os.path.exists('token.pickle'):
            with open(token_path, 'rb') as token:
                creds = pickle.load(token)
        
        if not creds or not creds.valid:
            if creds and creds.expired and creds.refresh_token:
                creds.refresh(Request())
            else:
                secret_path = if self.client_secret_path.value is not None self.client_secret_path.value else '/data/home/google_oauth_token.json'
                scopes = READWRITE_SCOPE if self.is_readwrite.value else READONLY_SCOPE
                flow = InstalledAppFlow.from_client_secrets_file(secret_path, scopes)
                creds = flow.run_local_server(port=0)
            
            with open(token_path, 'wb') as token:
                pickle.dump(creds, token)
                
        service = build('gmail', 'v1', credentials=creds)
        ctx['gmail_service'] = service
        
        results = service.users().labels().list(userId='me').execute()
        labels = results.get('labels', [])
        ctx['gmail_labels'] = labels
        
        self.labels.value = labels

