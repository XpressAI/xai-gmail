@xai_component
class GmailGetMessage(Component):
    message_ref: InCompArg[dict]
    message: OutArg[dict]
    message_text: OutArg[str]
    
    
    def execute(self, ctx) -> None:
        # create gmail api client
        service = ctx['gmail_service']

        message = service.users().messages().get(userId="me", id=self.message_ref.value['id']).execute()
        
        self.message.value = message
        try:
            parts = message['payload']['parts']
            for part in parts:
                if part['mimeType'] == 'text/plain':
                    charset = 'UTF-8'
                    for header in part['headers']:
                        if header['name'] == 'Content-Type':
                            charset_pattern = r'charset[=]["\']?(.+?)["\']?$'
                            match = re.search(charset_pattern, header['value'])
                            if match:
                                charset = match.group(1)
                    self.message_text.value = base64.urlsafe_b64decode(part['body']['data']).decode(charset)
        except Exception as e:
            print(e)
            self.message_text.value = None


